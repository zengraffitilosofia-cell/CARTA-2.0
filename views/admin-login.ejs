<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NFC Menu · Admin</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .login-product-logo {
      display: block;
      width: 90px;
      object-fit: contain;
      margin: 0 auto 20px;
      filter: drop-shadow(0 2px 10px rgba(101,45,144,0.20));
    }
  </style>
</head>
<body>
  <main class="login-page">

    <img src="data:image/png;base64," alt="NFC Menu" class="login-product-logo">

    <div class="card card--login">
      <h1 class="login-title">Panel de administración</h1>
      <p class="login-subtitle">Acceso restringido</p>

      <% if (error) { %>
        <div class="alert alert--error"><%= error %></div>
      <% } %>

      <form method="POST" action="/admin/login" class="login-form">
        <% if (typeof csrfToken !== 'undefined') { %>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% } %>
        <div>
          <label for="pw">Contraseña</label>
          <input type="password" id="pw" name="password"
                 placeholder="••••••••" autofocus required>
        </div>
        <button type="submit" class="btn btn--primary" style="width:100%">Entrar</button>
      </form>
    </div>

  </main>
</body>
</html>
