<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NFC Menu · Admin</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .login-logo-header {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      margin-bottom: 24px;
    }
    .login-product-logo {
      width: 90px;
      object-fit: contain;
      filter: drop-shadow(0 2px 8px rgba(101,45,144,0.18));
    }
  </style>
</head>
<body>
  <main class="login-page">

    <div class="login-logo-header">
      <!-- Logo NFC Menu — coloca NFCMENU.png en tu carpeta public/ -->
      <img
        src="/NFCMENU.png"
        alt="NFC Menu"
        class="login-product-logo">
    </div>

    <div class="card card--login">
      <h1 class="login-title">Panel de administración</h1>
      <p class="login-subtitle">Acceso restringido</p>

      <% if (error) { %>
        <div class="alert alert--error"><%= error %></div>
      <% } %>

      <form method="POST" action="/admin/login" class="login-form">
        <% if (typeof csrfToken !== 'undefined') { %>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% } %>
        <div>
          <label for="pw">Contraseña</label>
          <input type="password" id="pw" name="password" placeholder="••••••••" autofocus required>
        </div>
        <button type="submit" class="btn btn--primary" style="width:100%">Entrar</button>
      </form>
    </div>

  </main>
</body>
</html>
