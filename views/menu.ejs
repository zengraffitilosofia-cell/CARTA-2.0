<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= menu.name %><% if (menu.restaurant_name) { %> · <%= menu.restaurant_name %><% } %></title>
  <link rel="stylesheet" href="/style.css">

  <style>
    .menu-cat-body {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s ease;
    }

    .menu-cat-body.open {
      padding: 10px 0;
    }

    .menu-cat-header {
      cursor: pointer;
    }
  </style>
</head>
<body class="menu-pub-page">

  <header class="menu-pub-header">
    <% if (menu.logo_url) { %>
      <img src="<%= menu.logo_url %>" alt="<%= menu.restaurant_name || menu.name %>" class="menu-pub-logo">
    <% } %>
    <% if (menu.restaurant_name) { %>
      <p class="menu-pub-restaurant"><%= menu.restaurant_name %></p>
    <% } %>
    <h1 class="menu-pub-title"><%= menu.name %></h1>
    <% if (menu.description) { %>
      <p class="menu-pub-desc"><%= menu.description %></p>
    <% } %>
  </header>

  <main class="menu-pub-body">
    <% if (categories.length === 0) { %>
      <p class="empty-state" style="text-align:center;padding:40px">Esta carta no tiene contenido todavía.</p>
    <% } %>

    <% categories.forEach(cat => {
         const dishes = dishesByCategory[cat.id] || [];
    %>
      <div class="menu-cat">
        <div class="menu-cat-header menu-cat-title"><%= cat.name %></div>

        <div class="menu-cat-body">
          <% if (dishes.length === 0) { %>
            <p class="empty-state" style="padding:12px">Sin platos en esta categoría.</p>
          <% } else { %>
            <div class="menu-dishes">
              <% dishes.forEach(dish => { %>
                <div class="menu-dish-card">
                  <% if (dish.image_url) { %>
                    <img src="<%= dish.image_url %>" alt="<%= dish.name %>" class="menu-dish-img">
                  <% } %>
                  <div class="menu-dish-info">
                    <div class="menu-dish-header">
                      <strong class="menu-dish-name"><%= dish.name %></strong>
                      <% if (dish.price != null) { %>
                        <span class="menu-dish-price"><%= Number(dish.price).toFixed(2) %> €</span>
                      <% } %>
                    </div>
                    <% if (dish.description) { %>
                      <p class="menu-dish-desc"><%= dish.description %></p>
                    <% } %>
                    <% if (dish.allergens) { %>
                      <p class="menu-dish-alg"><strong>Alérgenos:</strong> <%= dish.allergens %></p>
                    <% } %>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    <% }) %>
  </main>

  <script>
    document.querySelectorAll('.menu-cat-header').forEach(header => {
      header.addEventListener('click', () => {
        const body = header.nextElementSibling;
        const isOpen = body.classList.contains('open');

        // cerrar todas
        document.querySelectorAll('.menu-cat-body').forEach(b => {
          b.classList.remove('open');
          b.style.maxHeight = null;
        });

        if (!isOpen) {
          body.classList.add('open');
          body.style.maxHeight = body.scrollHeight + "px";

          // scroll suave
          setTimeout(() => {
            header.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }, 200);
        }
      });
    });
  </script>

</body>
</html>
